{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "rootDir": "src",
        "lib": ["ES2020", "DOM"],
        "types": ["chrome"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
